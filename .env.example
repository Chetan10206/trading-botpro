# ─────────────────────────────────────────────────────────────────────────
#  NY Open FVG Bot  —  Environment Variables
#
#  HOW TO USE
#  ──────────────────────────────────────────────────────────────────────
#  1. Copy this file:   cp .env.example .env
#  2. Fill in your keys below
#  3. NEVER commit .env to git  (it is already in .gitignore)
#
#  GET ALPACA KEYS
#  ──────────────────────────────────────────────────────────────────────
#  1. Sign up (free):  https://app.alpaca.markets
#  2. Dashboard → API Keys → Generate New Key
#  3. Paper keys start with PK…  (safe for backtesting)
#     Live  keys start with AK…  (real money — be careful!)
# ─────────────────────────────────────────────────────────────────────────


# ── Alpaca API credentials ────────────────────────────────────────────────

# Your Alpaca API Key ID  (paper: starts with PK, live: starts with AK)
ALPACA_API_KEY=your_alpaca_api_key_here

# Your Alpaca Secret Key  (shown ONCE at generation — save it!)
ALPACA_SECRET_KEY=your_alpaca_secret_key_here


# ── Optional overrides ────────────────────────────────────────────────────

# Default data source: yfinance | alpaca
# DATA_SOURCE=yfinance

# Default symbol for CLI quick-runs
# DEFAULT_SYMBOL=SPY

# Log level: DEBUG | INFO | WARNING | ERROR
# LOG_LEVEL=INFO# ─────────────────────────────────────────────────────────────────────────
